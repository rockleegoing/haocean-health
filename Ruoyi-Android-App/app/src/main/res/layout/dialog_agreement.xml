<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:padding="20dp"
    android:radius="16dp"
    android:shape="rectangle">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="15dp">

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/ic_lock_shield_background"
            android:gravity="center"
            android:text="@string/lock_icon"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <!-- 标题文字 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/privacy_title"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 内容滚动区域：包含隐私政策文本 -->
    <ScrollView
        android:layout_width="280dp"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp">

        <TextView
            android:id="@+id/tv_privacy_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="4sp"
            android:text="@string/privacy_desc"
            android:textColor="#333333"
            android:textSize="14sp" />
    </ScrollView>

    <!-- 底部按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="15dp">

        <!-- 拒绝按钮 -->
        <TextView
            android:id="@+id/btn_refuse"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:gravity="center"
            android:background="@drawable/btn_disguise_white"
            android:text="@string/btn_refuse"
            android:textColor="#666666" />

        <!-- 同意按钮 -->
        <TextView
            android:id="@+id/btn_agree"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:background="@drawable/btn_disguise_pink"
            android:text="@string/btn_agree"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".activity.mine.InfoActivity">

    <com.hjq.bar.TitleBar
        android:id="@id/titlebar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_48"
        app:lineVisible="false"
        app:leftIcon="@mipmap/icon_title_left"
        app:title="@string/mine_edit_info" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="@dimen/dp_10"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:text="*"
            android:textColor="@color/red"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="15dp"
            android:text="@string/edit_user_nickname"
            android:textColor="@color/black"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginEnd="15dp"
            android:background="@drawable/shape_bg_pwd"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/et_name"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:maxLength="24"
                tools:text="若依"
                android:background="@color/white"
                android:hint="@string/edit_p_nickname" />

            <ImageView
                android:id="@+id/iv_clear_name"
                android:layout_width="@dimen/dp_22"
                android:layout_height="@dimen/dp_22"
                android:layout_marginEnd="15dp"
                android:visibility="invisible"
                android:src="@mipmap/icon_edit_clear_default" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@color/white"
        android:layout_marginTop="@dimen/dp_10"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:text="*"
            android:textColor="@color/red"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="15dp"
            android:text="@string/edit_mobile"
            android:textColor="@color/black"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginEnd="15dp"
            android:background="@drawable/shape_bg_pwd"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/et_mobile"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:inputType="number"
                tools:text="15888888888"
                android:background="@color/white"
                android:hint="@string/login_p_phone" />

            <ImageView
                android:id="@+id/iv_clear_mobile"
                android:layout_width="@dimen/dp_22"
                android:layout_height="@dimen/dp_22"
                android:layout_marginEnd="15dp"
                android:visibility="invisible"
                android:src="@mipmap/icon_edit_clear_default" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_height="50dp"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:text="*"
            android:textColor="@color/red"
            android:textSize="16sp" />

        <TextView
            android:layout_width="@dimen/dp_60"
            android:layout_height="wrap_content"
            android:layout_marginEnd="15dp"
            android:text="@string/edit_email"
            android:textColor="@color/black"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginEnd="15dp"
            android:background="@drawable/shape_bg_pwd"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/et_email"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:inputType="textEmailAddress"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                tools:text="ry@163.com"
                android:background="@color/white"
                android:hint="@string/login_p_email" />

            <ImageView
                android:id="@+id/iv_clear_email"
                android:layout_width="@dimen/dp_22"
                android:layout_height="@dimen/dp_22"
                android:layout_marginEnd="15dp"
                android:visibility="invisible"
                android:src="@mipmap/icon_edit_clear_default" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:text="*"
            android:textColor="@color/red"
            android:textSize="16sp" />

        <TextView
            android:layout_width="@dimen/dp_60"
            android:layout_height="wrap_content"
            android:layout_marginRight="15dp"
            android:text="@string/gender"
            android:textColor="@color/black"
            android:textSize="16sp" />

        <com.hjq.shape.view.ShapeRadioButton
            android:id="@+id/radio_male"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_margin="10dp"
            android:background="@null"
            android:checked="true"
            android:gravity="center"
            android:padding="10dp"
            android:text="@string/male"
            android:textSize="14sp"
            app:shape_buttonCheckedDrawable="@drawable/radiobutton_checked_ic"
            app:shape_buttonDrawable="@drawable/radiobutton_normal_ic" />

        <com.hjq.shape.view.ShapeRadioButton
            android:id="@+id/radio_female"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_margin="10dp"
            android:background="@null"
            android:gravity="center"
            android:padding="10dp"
            android:text="@string/female"
            android:textSize="14sp"
            app:shape_buttonCheckedDrawable="@drawable/radiobutton_checked_ic"
            app:shape_buttonDrawable="@drawable/radiobutton_normal_ic" />

    </LinearLayout>

    <com.hjq.shape.view.ShapeButton
        android:id="@+id/btn_submit"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="@dimen/dp_40"
        android:layout_marginRight="15dp"
        android:gravity="center"
        android:text="@string/submit"
        android:textColor="@color/white"
        app:shape="rectangle"
        app:shape_radius="6dp"
        app:shape_solidColor="#0081ff"
        app:shape_solidPressedColor="#AA5A8DDF" />

</LinearLayout>
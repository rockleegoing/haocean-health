        <result property="qualitativeBasis"    column="qualitative_basis"    />
        <result property="handlingBasis"    column="handling_basis"    />
        <result property="standardPhrase"    column="standard_phrase"    />
        <result property="supervisoryOpinion"    column="supervisory_opinion"    />
        <result property="handlingContent"    column="handling_content"    />
        <result property="handlingProcedure"    column="handling_procedure"    />

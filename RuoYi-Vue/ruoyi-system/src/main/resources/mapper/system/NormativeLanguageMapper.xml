            <if test="handlingContent != null">handling_content = #{handlingContent},</if>
            <if test="handlingProcedure != null">handling_procedure = #{handlingProcedure},</if>
            <if test="administrativePenalty != null">administrative_penalty = #{administrativePenalty},</if>
            <if test="administrativeForcedMeasures != null">administrative_forced_measures = #{administrativeForcedMeasures},</if>
            <if test="otherHandling != null">other_handling = #{otherHandling},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="isDeleted != null">is_deleted = #{isDeleted},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteNormativeLanguageById" parameterType="Long">
        delete from normative_language where id = #{id}
    </delete>

    <delete id="deleteNormativeLanguageByIds" parameterType="String">
        delete from normative_language where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>

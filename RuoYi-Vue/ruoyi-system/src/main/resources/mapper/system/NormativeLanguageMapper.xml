    <sql id="selectNormativeLanguageVo">
        select id, professional_category, primary_category, secondary_category, tertiary_category, standard_code, violation_code, information_report, inspection_content, qualitative_basis, handling_basis, standard_phrase, supervisory_opinion, handling_content, handling_procedure, administrative_penalty, administrative_forced_measures, other_handling, create_time, is_deleted from normative_language
    </sql>

    <select id="selectNormativeLanguageList" parameterType="NormativeLanguage" resultMap="NormativeLanguageResult">
        <include refid="selectNormativeLanguageVo"/>
        <where>  
            <if test="professionalCategory != null "> and professional_category = #{professionalCategory}</if>
            <if test="primaryCategory != null "> and primary_category = #{primaryCategory}</if>
            <if test="secondaryCategory != null "> and secondary_category = #{secondaryCategory}</if>
            <if test="tertiaryCategory != null "> and tertiary_category = #{tertiaryCategory}</if>
            <if test="standardCode != null  and standardCode != ''"> and standard_code = #{standardCode}</if>
            <if test="violationCode != null  and violationCode != ''"> and violation_code = #{violationCode}</if>
            <if test="informationReport != null  and informationReport != ''"> and information_report = #{informationReport}</if>
            <if test="inspectionContent != null  and inspectionContent != ''"> and inspection_content = #{inspectionContent}</if>
            <if test="qualitativeBasis != null  and qualitativeBasis != ''"> and qualitative_basis = #{qualitativeBasis}</if>
            <if test="handlingBasis != null  and handlingBasis != ''"> and handling_basis = #{handlingBasis}</if>
            <if test="standardPhrase != null  and standardPhrase != ''"> and standard_phrase = #{standardPhrase}</if>
            <if test="supervisoryOpinion != null  and supervisoryOpinion != ''"> and supervisory_opinion = #{supervisoryOpinion}</if>
            <if test="handlingContent != null  and handlingContent != ''"> and handling_content = #{handlingContent}</if>
            <if test="handlingProcedure != null  and handlingProcedure != ''"> and handling_procedure = #{handlingProcedure}</if>
            <if test="administrativePenalty != null  and administrativePenalty != ''"> and administrative_penalty = #{administrativePenalty}</if>
            <if test="administrativeForcedMeasures != null  and administrativeForcedMeasures != ''"> and administrative_forced_measures = #{administrativeForcedMeasures}</if>
            <if test="otherHandling != null  and otherHandling != ''"> and other_handling = #{otherHandling}</if>
            <if test="isDeleted != null "> and is_deleted = #{isDeleted}</if>
        </where>
    </select>
    
    <select id="selectNormativeLanguageById" parameterType="Long" resultMap="NormativeLanguageResult">
        <include refid="selectNormativeLanguageVo"/>
        where id = #{id}
    </select>

    <insert id="insertNormativeLanguage" parameterType="NormativeLanguage" useGeneratedKeys="true" keyProperty="id">
        insert into normative_language
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="professionalCategory != null">professional_category,</if>
            <if test="primaryCategory != null">primary_category,</if>
            <if test="secondaryCategory != null">secondary_category,</if>
            <if test="tertiaryCategory != null">tertiary_category,</if>
            <if test="standardCode != null">standard_code,</if>

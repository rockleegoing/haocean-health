            <if test="supervisoryOpinion != null">#{supervisoryOpinion},</if>
            <if test="handlingContent != null">#{handlingContent},</if>
            <if test="handlingProcedure != null">#{handlingProcedure},</if>
            <if test="administrativePenalty != null">#{administrativePenalty},</if>

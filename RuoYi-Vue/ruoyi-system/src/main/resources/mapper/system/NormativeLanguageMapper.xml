            <if test="handlingBasis != null">handling_basis,</if>
            <if test="standardPhrase != null">standard_phrase,</if>
            <if test="supervisoryOpinion != null">supervisory_opinion,</if>
            <if test="handlingContent != null">handling_content,</if>

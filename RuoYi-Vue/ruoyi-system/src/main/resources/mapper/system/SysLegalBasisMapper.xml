<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysLegalBasisMapper">

    <resultMap type="SysLegalBasis" id="SysLegalBasisResult">
        <result property="basisId" column="basis_id"/>
        <result property="basisNo" column="basis_no"/>
        <result property="title" column="title"/>
        <result property="violationType" column="violation_type"/>
        <result property="issuingAuthority" column="issuing_authority"/>
        <result property="effectiveDate" column="effective_date"/>
        <result property="legalLevel" column="legal_level"/>
        <result property="clauses" column="clauses"/>
        <result property="legalLiability" column="legal_liability"/>
        <result property="discretionStandard" column="discretion_standard"/>
        <result property="regulationId" column="regulation_id"/>
        <result property="status" column="status"/>
        <result property="delFlag" column="del_flag"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectSysLegalBasisVo">
        select basis_id, basis_no, title, violation_type, issuing_authority, effective_date,
               legal_level, clauses, legal_liability, discretion_standard, regulation_id,
               status, del_flag, create_by, create_time, update_by, update_time, remark
        from sys_legal_basis
    </sql>

    <select id="selectSysLegalBasisList" parameterType="SysLegalBasis" resultMap="SysLegalBasisResult">
        <include refid="selectSysLegalBasisVo"/>
        <where>
            <if test="title != null and title != ''">and title like concat('%', #{title}, '%')</if>
            <if test="violationType != null and violationType != ''">and violation_type = #{violationType}</if>
            <if test="basisNo != null and basisNo != ''">and basis_no = #{basisNo}</if>
            <if test="regulationId != null">and regulation_id = #{regulationId}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="delFlag != null and delFlag != ''">and del_flag = #{delFlag}</if>
            <if test="updateTimeFrom != null and updateTimeFrom != ''">and update_time &gt;= #{updateTimeFrom}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectSysLegalBasisById" parameterType="Long" resultMap="SysLegalBasisResult">
        <include refid="selectSysLegalBasisVo"/>
        where basis_id = #{basisId}
    </select>

    <select id="selectSysLegalBasisListByRegulationId" resultMap="SysLegalBasisResult">
        <include refid="selectSysLegalBasisVo"/>
        where regulation_id = #{regulationId} and del_flag = '0'
        order by basis_no asc
    </select>

    <insert id="insertSysLegalBasis" parameterType="SysLegalBasis" useGeneratedKeys="true" keyProperty="basisId">
        insert into sys_legal_basis
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="basisNo != null and basisNo != ''">basis_no,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="violationType != null">violation_type,</if>
            <if test="issuingAuthority != null">issuing_authority,</if>
            <if test="effectiveDate != null">effective_date,</if>
            <if test="legalLevel != null">legal_level,</if>
            <if test="clauses != null">clauses,</if>
            <if test="legalLiability != null">legal_liability,</if>
            <if test="discretionStandard != null">discretion_standard,</if>
            <if test="regulationId != null">regulation_id,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="basisNo != null and basisNo != ''">#{basisNo},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="violationType != null">#{violationType},</if>
            <if test="issuingAuthority != null">#{issuingAuthority},</if>
            <if test="effectiveDate != null">#{effectiveDate},</if>
            <if test="legalLevel != null">#{legalLevel},</if>
            <if test="clauses != null">#{clauses},</if>
            <if test="legalLiability != null">#{legalLiability},</if>
            <if test="discretionStandard != null">#{discretionStandard},</if>
            <if test="regulationId != null">#{regulationId},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateSysLegalBasis" parameterType="SysLegalBasis">
        update sys_legal_basis
        <trim prefix="SET" suffixOverrides=",">
            <if test="basisNo != null">basis_no = #{basisNo},</if>
            <if test="title != null">title = #{title},</if>
            <if test="violationType != null">violation_type = #{violationType},</if>
            <if test="issuingAuthority != null">issuing_authority = #{issuingAuthority},</if>
            <if test="effectiveDate != null">effective_date = #{effectiveDate},</if>
            <if test="legalLevel != null">legal_level = #{legalLevel},</if>
            <if test="clauses != null">clauses = #{clauses},</if>
            <if test="legalLiability != null">legal_liability = #{legalLiability},</if>
            <if test="discretionStandard != null">discretion_standard = #{discretionStandard},</if>
            <if test="regulationId != null">regulation_id = #{regulationId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where basis_id = #{basisId}
    </update>

    <delete id="deleteSysLegalBasisById" parameterType="Long">
        update sys_legal_basis set del_flag = '1' where basis_id = #{basisId}
    </delete>

    <delete id="deleteSysLegalBasisByIds" parameterType="String">
        update sys_legal_basis set del_flag = '1' where basis_id in
        <foreach item="basisId" collection="array" open="(" separator="," close=")">
            #{basisId}
        </foreach>
    </delete>

</mapper>

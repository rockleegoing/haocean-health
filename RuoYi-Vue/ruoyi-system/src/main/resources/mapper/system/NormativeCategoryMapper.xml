<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.NormativeCategoryMapper">
    
    <resultMap type="NormativeCategory" id="NormativeCategoryResult">
        <result property="code"    column="code"    />
        <result property="name"    column="name"    />
        <result property="parentCode"    column="parent_code"    />
    </resultMap>

    <sql id="selectNormativeCategoryVo">
        select code, name, parent_code from normative_category
    </sql>

    <select id="selectNormativeCategoryList" parameterType="NormativeCategory" resultMap="NormativeCategoryResult">
        <include refid="selectNormativeCategoryVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="parentCode != null "> and parent_code = #{parentCode}</if>
        </where>
    </select>
    
    <select id="selectNormativeCategoryByCode" parameterType="Long" resultMap="NormativeCategoryResult">
        <include refid="selectNormativeCategoryVo"/>
        where code = #{code}
    </select>

    <insert id="insertNormativeCategory" parameterType="NormativeCategory">
        insert into normative_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="code != null">code,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="parentCode != null">parent_code,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="code != null">#{code},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="parentCode != null">#{parentCode},</if>
         </trim>
    </insert>

    <update id="updateNormativeCategory" parameterType="NormativeCategory">
        update normative_category
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="parentCode != null">parent_code = #{parentCode},</if>
        </trim>
        where code = #{code}
    </update>

    <delete id="deleteNormativeCategoryByCode" parameterType="Long">
        delete from normative_category where code = #{code}
    </delete>

    <delete id="deleteNormativeCategoryByCodes" parameterType="String">
        delete from normative_category where code in 
        <foreach item="code" collection="array" open="(" separator="," close=")">
            #{code}
        </foreach>
    </delete>
</mapper>
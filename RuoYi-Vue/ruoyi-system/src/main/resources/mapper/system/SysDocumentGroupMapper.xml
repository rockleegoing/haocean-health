<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysDocumentGroupMapper">

    <resultMap type="SysDocumentGroup" id="SysDocumentGroupResult">
        <result property="id"             column="id"             />
        <result property="groupCode"       column="group_code"       />
        <result property="groupName"      column="group_name"      />
        <result property="groupType"      column="group_type"      />
        <result property="templates"      column="templates"      />
        <result property="isActive"       column="is_active"       />
        <result property="delFlag"        column="del_flag"        />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
    </resultMap>

    <sql id="selectSysDocumentGroupVo">
        select id, group_code, group_name, group_type, templates, is_active,
               del_flag, create_by, create_time, update_by, update_time, remark
        from sys_document_group
    </sql>

    <select id="selectSysDocumentGroupList" parameterType="SysDocumentGroup" resultMap="SysDocumentGroupResult">
        <include refid="selectSysDocumentGroupVo"/>
        <where>
            del_flag = '0'
            <if test="groupCode != null and groupCode != ''">
                and group_code = #{groupCode}
            </if>
            <if test="groupName != null and groupName != ''">
                and group_name like concat('%', #{groupName}, '%')
            </if>
            <if test="groupType != null and groupType != ''">
                and group_type = #{groupType}
            </if>
            <if test="isActive != null and isActive != ''">
                and is_active = #{isActive}
            </if>
        </where>
        order by id asc
    </select>

    <select id="selectSysDocumentGroupById" parameterType="Long" resultMap="SysDocumentGroupResult">
        <include refid="selectSysDocumentGroupVo"/>
        where id = #{id}
    </select>

    <select id="selectAllSysDocumentGroups" resultMap="SysDocumentGroupResult">
        <include refid="selectSysDocumentGroupVo"/>
        where del_flag = '0' and is_active = '0'
        order by id asc
    </select>

    <insert id="insertSysDocumentGroup" parameterType="SysDocumentGroup" useGeneratedKeys="true" keyProperty="id">
        insert into sys_document_group
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="groupCode != null and groupCode != ''">group_code,</if>
            <if test="groupName != null and groupName != ''">group_name,</if>
            <if test="groupType != null and groupType != ''">group_type,</if>
            <if test="templates != null">templates,</if>
            <if test="isActive != null">is_active,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="groupCode != null and groupCode != ''">#{groupCode},</if>
            <if test="groupName != null and groupName != ''">#{groupName},</if>
            <if test="groupType != null and groupType != ''">#{groupType},</if>
            <if test="templates != null">#{templates},</if>
            <if test="isActive != null">#{isActive},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateSysDocumentGroup" parameterType="SysDocumentGroup">
        update sys_document_group
        <trim prefix="SET" suffixOverrides=",">
            <if test="groupCode != null and groupCode != ''">group_code = #{groupCode},</if>
            <if test="groupName != null and groupName != ''">group_name = #{groupName},</if>
            <if test="groupType != null and groupType != ''">group_type = #{groupType},</if>
            <if test="templates != null">templates = #{templates},</if>
            <if test="isActive != null">is_active = #{isActive},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSysDocumentGroupById" parameterType="Long">
        update sys_document_group set del_flag = '1' where id = #{id}
    </delete>

    <delete id="deleteSysDocumentGroupByIds" parameterType="String">
        update sys_document_group set del_flag = '1' where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

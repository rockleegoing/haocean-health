<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysSupervisionItemMapper">

    <resultMap type="SysSupervisionItem" id="SysSupervisionItemResult">
        <result property="itemId" column="item_id"/>
        <result property="itemNo" column="item_no"/>
        <result property="name" column="name"/>
        <result property="parentId" column="parent_id"/>
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="description" column="description"/>
        <result property="legalBasis" column="legal_basis"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectSysSupervisionItemVo">
        SELECT s.item_id, s.item_no, s.name, s.parent_id, s.category_id,
               c.category_name, s.description, s.legal_basis, s.sort_order,
               s.status, s.create_by, s.create_time, s.update_by, s.update_time, s.remark
        FROM sys_supervision_item s
        LEFT JOIN sys_supervision_category c ON s.category_id = c.category_id
    </sql>

    <select id="selectSysSupervisionItemList" parameterType="SysSupervisionItem" resultMap="SysSupervisionItemResult">
        <include refid="selectSysSupervisionItemVo"/>
        <where>
            <if test="itemNo != null and itemNo != ''">AND s.item_no LIKE CONCAT('%', #{itemNo}, '%')</if>
            <if test="name != null and name != ''">AND s.name LIKE CONCAT('%', #{name}, '%')</if>
            <if test="categoryId != null">AND s.category_id = #{categoryId}</if>
            <if test="parentId != null">AND s.parent_id = #{parentId}</if>
            <if test="status != null and status != ''">AND s.status = #{status}</if>
        </where>
        ORDER BY s.sort_order, s.create_time DESC
    </select>

    <select id="selectSupervisionItemListWithCategory" parameterType="SysSupervisionItem" resultMap="SysSupervisionItemResult">
        <include refid="selectSysSupervisionItemVo"/>
        <where>
            <if test="itemNo != null and itemNo != ''">AND s.item_no LIKE CONCAT('%', #{itemNo}, '%')</if>
            <if test="name != null and name != ''">AND s.name LIKE CONCAT('%', #{name}, '%')</if>
            <if test="categoryId != null">AND s.category_id = #{categoryId}</if>
            <if test="status != null and status != ''">AND s.status = #{status}</if>
        </where>
        ORDER BY s.sort_order, s.create_time DESC
    </select>

    <select id="selectSysSupervisionItemById" parameterType="Long" resultMap="SysSupervisionItemResult">
        <include refid="selectSysSupervisionItemVo"/>
        WHERE s.item_id = #{itemId}
    </select>

    <select id="selectSupervisionItemListByParentId" parameterType="Long" resultMap="SysSupervisionItemResult">
        <include refid="selectSysSupervisionItemVo"/>
        WHERE s.parent_id = #{parentId} AND s.status = '0'
        ORDER BY s.sort_order, s.create_time DESC
    </select>

    <select id="selectSupervisionItemListByCategoryId" parameterType="Long" resultMap="SysSupervisionItemResult">
        <include refid="selectSysSupervisionItemVo"/>
        WHERE s.category_id = #{categoryId} AND s.status = '0'
        ORDER BY s.sort_order, s.create_time DESC
    </select>

    <select id="searchSupervisionItem" resultMap="SysSupervisionItemResult">
        <include refid="selectSysSupervisionItemVo"/>
        WHERE s.status = '0'
        <if test="keyword != null and keyword != ''">
            AND (s.name LIKE CONCAT('%', #{keyword}, '%') OR s.description LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        <if test="categoryId != null">
            AND s.category_id = #{categoryId}
        </if>
        ORDER BY s.sort_order, s.create_time DESC
    </select>

    <insert id="insertSysSupervisionItem" parameterType="SysSupervisionItem" useGeneratedKeys="true" keyProperty="itemId">
        INSERT INTO sys_supervision_item
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="itemNo != null and itemNo != ''">item_no,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="description != null">description,</if>
            <if test="legalBasis != null">legal_basis,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="itemNo != null and itemNo != ''">#{itemNo},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="description != null">#{description},</if>
            <if test="legalBasis != null">#{legalBasis},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateSysSupervisionItem" parameterType="SysSupervisionItem">
        UPDATE sys_supervision_item
        <trim prefix="SET" suffixOverrides=",">
            <if test="itemNo != null and itemNo != ''">item_no = #{itemNo},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="description != null">description = #{description},</if>
            <if test="legalBasis != null">legal_basis = #{legalBasis},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        WHERE item_id = #{itemId}
    </update>

    <delete id="deleteSysSupervisionItemById" parameterType="Long">
        DELETE FROM sys_supervision_item WHERE item_id = #{itemId}
    </delete>

    <delete id="deleteSysSupervisionItemByIds" parameterType="String">
        DELETE FROM sys_supervision_item WHERE item_id IN
        <foreach item="itemId" collection="array" open="(" separator="," close=")">
            #{itemId}
        </foreach>
    </delete>

</mapper>

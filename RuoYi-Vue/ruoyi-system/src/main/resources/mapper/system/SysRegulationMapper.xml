<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysRegulationMapper">

    <resultMap type="SysRegulation" id="SysRegulationResult">
        <result property="regulationId" column="regulation_id"/>
        <result property="title" column="title"/>
        <result property="legalType" column="legal_type"/>
        <result property="supervisionTypes" column="supervision_types"/>
        <result property="publishDate" column="publish_date"/>
        <result property="effectiveDate" column="effective_date"/>
        <result property="issuingAuthority" column="issuing_authority"/>
        <result property="content" column="content"/>
        <result property="version" column="version"/>
        <result property="status" column="status"/>
        <result property="delFlag" column="del_flag"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <resultMap type="SysRegulationChapter" id="SysRegulationChapterResult">
        <result property="chapterId" column="chapter_id"/>
        <result property="regulationId" column="regulation_id"/>
        <result property="chapterNo" column="chapter_no"/>
        <result property="chapterTitle" column="chapter_title"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <resultMap type="SysRegulationArticle" id="SysRegulationArticleResult">
        <result property="articleId" column="article_id"/>
        <result property="chapterId" column="chapter_id"/>
        <result property="regulationId" column="regulation_id"/>
        <result property="articleNo" column="article_no"/>
        <result property="content" column="content"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectSysRegulationVo">
        select regulation_id, title, legal_type, supervision_types, publish_date, effective_date,
               issuing_authority, content, version, status, del_flag, create_by, create_time,
               update_by, update_time, remark from sys_regulation
    </sql>

    <select id="selectSysRegulationList" parameterType="SysRegulation" resultMap="SysRegulationResult">
        <include refid="selectSysRegulationVo"/>
        <where>
            <if test="title != null and title != ''">and title like concat('%', #{title}, '%')</if>
            <if test="legalType != null and legalType != ''">and legal_type = #{legalType}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="delFlag != null and delFlag != ''">and del_flag = #{delFlag}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectSysRegulationById" parameterType="Long" resultMap="SysRegulationResult">
        <include refid="selectSysRegulationVo"/>
        where regulation_id = #{regulationId}
    </select>

    <insert id="insertSysRegulation" parameterType="SysRegulation" useGeneratedKeys="true" keyProperty="regulationId">
        insert into sys_regulation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="legalType != null and legalType != ''">legal_type,</if>
            <if test="supervisionTypes != null">supervision_types,</if>
            <if test="publishDate != null">publish_date,</if>
            <if test="effectiveDate != null">effective_date,</if>
            <if test="issuingAuthority != null">issuing_authority,</if>
            <if test="content != null">content,</if>
            <if test="version != null">version,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="legalType != null and legalType != ''">#{legalType},</if>
            <if test="supervisionTypes != null">#{supervisionTypes},</if>
            <if test="publishDate != null">#{publishDate},</if>
            <if test="effectiveDate != null">#{effectiveDate},</if>
            <if test="issuingAuthority != null">#{issuingAuthority},</if>
            <if test="content != null">#{content},</if>
            <if test="version != null">#{version},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateSysRegulation" parameterType="SysRegulation">
        update sys_regulation
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="legalType != null and legalType != ''">legal_type = #{legalType},</if>
            <if test="supervisionTypes != null">supervision_types = #{supervisionTypes},</if>
            <if test="publishDate != null">publish_date = #{publishDate},</if>
            <if test="effectiveDate != null">effective_date = #{effectiveDate},</if>
            <if test="issuingAuthority != null">issuing_authority = #{issuingAuthority},</if>
            <if test="content != null">content = #{content},</if>
            <if test="version != null">version = #{version},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where regulation_id = #{regulationId}
    </update>

    <delete id="deleteSysRegulationById" parameterType="Long">
        update sys_regulation set del_flag = '1' where regulation_id = #{regulationId}
    </delete>

    <delete id="deleteSysRegulationByIds" parameterType="String">
        update sys_regulation set del_flag = '1' where regulation_id in
        <foreach item="regulationId" collection="array" open="(" separator="," close=")">
            #{regulationId}
        </foreach>
    </delete>

    <!-- 章节管理 -->
    <select id="selectChapterListByRegulationId" resultMap="SysRegulationChapterResult">
        select chapter_id, regulation_id, chapter_no, chapter_title, sort_order,
               create_by, create_time, update_by, update_time
        from sys_regulation_chapter
        where regulation_id = #{regulationId}
        order by sort_order asc
    </select>

    <insert id="insertSysRegulationChapter" parameterType="SysRegulationChapter" useGeneratedKeys="true" keyProperty="chapterId">
        insert into sys_regulation_chapter
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="regulationId != null">regulation_id,</if>
            <if test="chapterNo != null">chapter_no,</if>
            <if test="chapterTitle != null">chapter_title,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="regulationId != null">#{regulationId},</if>
            <if test="chapterNo != null">#{chapterNo},</if>
            <if test="chapterTitle != null">#{chapterTitle},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateSysRegulationChapter" parameterType="SysRegulationChapter">
        update sys_regulation_chapter
        <trim prefix="SET" suffixOverrides=",">
            <if test="chapterNo != null">chapter_no = #{chapterNo},</if>
            <if test="chapterTitle != null">chapter_title = #{chapterTitle},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where chapter_id = #{chapterId}
    </update>

    <delete id="deleteSysRegulationChapterById" parameterType="Long">
        delete from sys_regulation_chapter where chapter_id = #{chapterId}
    </delete>

    <delete id="deleteSysRegulationChapterByIds" parameterType="String">
        delete from sys_regulation_chapter where chapter_id in
        <foreach item="chapterId" collection="array" open="(" separator="," close=")">
            #{chapterId}
        </foreach>
    </delete>

    <!-- 条款管理 -->
    <select id="selectArticleListByRegulationId" resultMap="SysRegulationArticleResult">
        select article_id, chapter_id, regulation_id, article_no, content, sort_order,
               create_by, create_time, update_by, update_time
        from sys_regulation_article
        where regulation_id = #{regulationId}
        order by sort_order asc
    </select>

    <insert id="insertSysRegulationArticle" parameterType="SysRegulationArticle" useGeneratedKeys="true" keyProperty="articleId">
        insert into sys_regulation_article
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="chapterId != null">chapter_id,</if>
            <if test="regulationId != null">regulation_id,</if>
            <if test="articleNo != null">article_no,</if>
            <if test="content != null">content,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="chapterId != null">#{chapterId},</if>
            <if test="regulationId != null">#{regulationId},</if>
            <if test="articleNo != null">#{articleNo},</if>
            <if test="content != null">#{content},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateSysRegulationArticle" parameterType="SysRegulationArticle">
        update sys_regulation_article
        <trim prefix="SET" suffixOverrides=",">
            <if test="chapterId != null">chapter_id = #{chapterId},</if>
            <if test="articleNo != null">article_no = #{articleNo},</if>
            <if test="content != null">content = #{content},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where article_id = #{articleId}
    </update>

    <delete id="deleteSysRegulationArticleById" parameterType="Long">
        delete from sys_regulation_article where article_id = #{articleId}
    </delete>

    <delete id="deleteSysRegulationArticleByIds" parameterType="String">
        delete from sys_regulation_article where article_id in
        <foreach item="articleId" collection="array" open="(" separator="," close=")">
            #{articleId}
        </foreach>
    </delete>

</mapper>

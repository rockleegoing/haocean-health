<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysProcessingBasisMapper">

    <resultMap type="SysProcessingBasis" id="SysProcessingBasisResult">
        <result property="basisId" column="basis_id"/>
        <result property="title" column="title"/>
        <result property="regulationId" column="regulation_id"/>
        <result property="status" column="status"/>
        <result property="delFlag" column="del_flag"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectSysProcessingBasisVo">
        select basis_id, title, regulation_id, status, del_flag,
               create_by, create_time, update_by, update_time, remark
        from sys_processing_basis
    </sql>

    <select id="selectSysProcessingBasisList" parameterType="SysProcessingBasis" resultMap="SysProcessingBasisResult">
        <include refid="selectSysProcessingBasisVo"/>
        <where>
            <if test="title != null and title != ''">and title like concat('%', #{title}, '%')</if>
            <if test="regulationId != null">and regulation_id = #{regulationId}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="delFlag != null and delFlag != ''">and del_flag = #{delFlag}</if>
            <if test="updateTimeFrom != null and updateTimeFrom != ''">and update_time &gt;= #{updateTimeFrom}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectSysProcessingBasisById" parameterType="Long" resultMap="SysProcessingBasisResult">
        <include refid="selectSysProcessingBasisVo"/>
        where basis_id = #{basisId}
    </select>

    <select id="selectSysProcessingBasisListByRegulationId" resultMap="SysProcessingBasisResult">
        <include refid="selectSysProcessingBasisVo"/>
        where regulation_id = #{regulationId} and del_flag = '0'
        order by basis_id asc
    </select>

    <insert id="insertSysProcessingBasis" parameterType="SysProcessingBasis" useGeneratedKeys="true" keyProperty="basisId">
        insert into sys_processing_basis
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="regulationId != null">regulation_id,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="regulationId != null">#{regulationId},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateSysProcessingBasis" parameterType="SysProcessingBasis">
        update sys_processing_basis
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null">title = #{title},</if>
            <if test="regulationId != null">regulation_id = #{regulationId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where basis_id = #{basisId}
    </update>

    <delete id="deleteSysProcessingBasisById" parameterType="Long">
        update sys_processing_basis set del_flag = '1' where basis_id = #{basisId}
    </delete>

    <delete id="deleteSysProcessingBasisByIds" parameterType="String">
        update sys_processing_basis set del_flag = '1' where basis_id in
        <foreach item="basisId" collection="array" open="(" separator="," close=")">
            #{basisId}
        </foreach>
    </delete>

</mapper>

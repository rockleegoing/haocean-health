<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysSupervisionCategoryMapper">

    <resultMap type="SysSupervisionCategory" id="SysSupervisionCategoryResult">
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="categoryCode" column="category_code"/>
        <result property="icon" column="icon"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectSysSupervisionCategoryVo">
        SELECT category_id, category_name, category_code, icon, sort_order, status, create_by, create_time, update_by, update_time, remark
        FROM sys_supervision_category
    </sql>

    <select id="selectSysSupervisionCategoryList" parameterType="SysSupervisionCategory" resultMap="SysSupervisionCategoryResult">
        <include refid="selectSysSupervisionCategoryVo"/>
        <where>
            <if test="categoryName != null and categoryName != ''">AND category_name LIKE CONCAT('%', #{categoryName}, '%')</if>
            <if test="categoryCode != null and categoryCode != ''">AND category_code = #{categoryCode}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        ORDER BY sort_order, create_time DESC
    </select>

    <select id="selectSysSupervisionCategoryById" parameterType="Long" resultMap="SysSupervisionCategoryResult">
        <include refid="selectSysSupervisionCategoryVo"/>
        WHERE category_id = #{categoryId}
    </select>

    <select id="selectAllCategories" resultMap="SysSupervisionCategoryResult">
        <include refid="selectSysSupervisionCategoryVo"/>
        WHERE status = '0'
        ORDER BY sort_order, create_time ASC
    </select>

    <insert id="insertSysSupervisionCategory" parameterType="SysSupervisionCategory" useGeneratedKeys="true" keyProperty="categoryId">
        INSERT INTO sys_supervision_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">category_name,</if>
            <if test="categoryCode != null and categoryCode != ''">category_code,</if>
            <if test="icon != null">icon,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">#{categoryName},</if>
            <if test="categoryCode != null and categoryCode != ''">#{categoryCode},</if>
            <if test="icon != null">#{icon},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateSysSupervisionCategory" parameterType="SysSupervisionCategory">
        UPDATE sys_supervision_category
        <trim prefix="SET" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="categoryCode != null and categoryCode != ''">category_code = #{categoryCode},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        WHERE category_id = #{categoryId}
    </update>

    <delete id="deleteSysSupervisionCategoryById" parameterType="Long">
        DELETE FROM sys_supervision_category WHERE category_id = #{categoryId}
    </delete>

    <delete id="deleteSysSupervisionCategoryByIds" parameterType="String">
        DELETE FROM sys_supervision_category WHERE category_id IN
        <foreach item="categoryId" collection="array" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </delete>

</mapper>

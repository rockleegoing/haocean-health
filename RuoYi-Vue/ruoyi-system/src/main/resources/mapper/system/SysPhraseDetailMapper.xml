<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysPhraseDetailMapper">

    <resultMap type="SysPhraseDetail" id="SysPhraseDetailResult">
        <result property="detailId"       column="detail_id"       />
        <result property="itemId"         column="item_id"         />
        <result property="detailTitle"    column="detail_title"    />
        <result property="detailContent" column="detail_content"  />
        <result property="detailType"     column="detail_type"     />
        <result property="sortOrder"      column="sort_order"       />
        <result property="version"        column="version"         />
        <result property="delFlag"        column="del_flag"        />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
        <result property="itemName"       column="item_name"       />
    </resultMap>

    <sql id="selectSysPhraseDetailVo">
        select d.detail_id, d.item_id, d.detail_title, d.detail_content,
               d.detail_type, d.sort_order, d.version, d.del_flag,
               d.create_by, d.create_time, d.update_by, d.update_time, d.remark,
               i.item_name
        from sys_phrase_detail d
        left join sys_phrase_item i on d.item_id = i.item_id
    </sql>

    <select id="selectSysPhraseDetailList" parameterType="SysPhraseDetail" resultMap="SysPhraseDetailResult">
        <include refid="selectSysPhraseDetailVo"/>
        <where>
            d.del_flag = '0'
            <if test="detailTitle != null and detailTitle != ''">
                and d.detail_title like concat('%', #{detailTitle}, '%')
            </if>
            <if test="detailContent != null and detailContent != ''">
                and d.detail_content like concat('%', #{detailContent}, '%')
            </if>
            <if test="itemId != null">
                and d.item_id = #{itemId}
            </if>
            <if test="detailType != null and detailType != ''">
                and d.detail_type = #{detailType}
            </if>
        </where>
        order by d.sort_order asc, d.detail_id asc
    </select>

    <select id="selectSysPhraseDetailByDetailId" parameterType="Long" resultMap="SysPhraseDetailResult">
        <include refid="selectSysPhraseDetailVo"/>
        where d.detail_id = #{detailId}
    </select>

    <select id="selectSysPhraseDetailByItemId" parameterType="Long" resultMap="SysPhraseDetailResult">
        <include refid="selectSysPhraseDetailVo"/>
        where d.item_id = #{itemId} and d.del_flag = '0'
        order by d.sort_order asc, d.detail_id asc
    </select>

    <select id="selectAllSysPhraseDetails" resultMap="SysPhraseDetailResult">
        <include refid="selectSysPhraseDetailVo"/>
        where d.del_flag = '0'
        order by d.sort_order asc, d.detail_id asc
    </select>

    <select id="selectChangedSysPhraseDetails" parameterType="Integer" resultMap="SysPhraseDetailResult">
        <include refid="selectSysPhraseDetailVo"/>
        where d.del_flag = '0' and d.version > #{version}
        order by d.version asc
    </select>

    <select id="selectMaxVersion" resultType="Integer">
        select max(version) from sys_phrase_detail
    </select>

    <insert id="insertSysPhraseDetail" parameterType="SysPhraseDetail" useGeneratedKeys="true" keyProperty="detailId">
        insert into sys_phrase_detail
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="itemId != null">item_id,</if>
            <if test="detailTitle != null and detailTitle != ''">detail_title,</if>
            <if test="detailContent != null and detailContent != ''">detail_content,</if>
            <if test="detailType != null">detail_type,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="version != null">version,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="itemId != null">#{itemId},</if>
            <if test="detailTitle != null and detailTitle != ''">#{detailTitle},</if>
            <if test="detailContent != null and detailContent != ''">#{detailContent},</if>
            <if test="detailType != null">#{detailType},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="version != null">#{version},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateSysPhraseDetail" parameterType="SysPhraseDetail">
        update sys_phrase_detail
        <trim prefix="SET" suffixOverrides=",">
            <if test="itemId != null">item_id = #{itemId},</if>
            <if test="detailTitle != null and detailTitle != ''">detail_title = #{detailTitle},</if>
            <if test="detailContent != null and detailContent != ''">detail_content = #{detailContent},</if>
            <if test="detailType != null">detail_type = #{detailType},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="version != null">version = #{version},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where detail_id = #{detailId}
    </update>

    <delete id="deleteSysPhraseDetailByDetailId" parameterType="Long">
        update sys_phrase_detail set del_flag = '1' where detail_id = #{detailId}
    </delete>

    <delete id="deleteSysPhraseDetailByDetailIds" parameterType="String">
        update sys_phrase_detail set del_flag = '1' where detail_id in
        <foreach item="detailId" collection="array" open="(" separator="," close=")">
            #{detailId}
        </foreach>
    </delete>

</mapper>
